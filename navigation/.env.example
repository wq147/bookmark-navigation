# Container runtime
DATABASE_URL=sqlite:////data/navigation.db
NAV_BACKUP_DIR=/data/backups
NAV_BOOKMARK_POLICY_PATH=/config/bookmark_policy.json
NAV_IMPORT_MAX_BYTES=2097152
NAV_IMPORT_BATCH_TTL_SECONDS=86400
# The host reverse proxy reaches the published port through this fixed bridge
# gateway, so Uvicorn trusts exactly that immediate proxy by default.
NAV_TRUSTED_PROXY_IPS=172.30.0.1

# Compose host settings (keep the default loopback binding behind HTTPS)
NAV_BIND_ADDRESS=127.0.0.1
NAV_PORT=8080
NAV_DATA_DIR=./data
NAV_IMAGE_TAG=local
NAV_DOCKER_SUBNET=172.30.0.0/24
NAV_DOCKER_GATEWAY=172.30.0.1
NAV_APP_IP=172.30.0.2

# Used only by the one-time administrator initialization command. The first
# browser login must replace this temporary password.
NAV_INITIAL_PASSWORD_FILE=/data/.navigation-initial-password
